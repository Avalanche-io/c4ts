{
  "name": "@avalanche-io/c4",
  "version": "1.0.5",
  "description": "C4 Universal Content Identification — TypeScript implementation",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": [
    "c4",
    "content-addressing",
    "sha-512",
    "manifest",
    "c4m",
    "SMPTE",
    "ST2114"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Avalanche-io/c4ts.git",
    "directory": "packages/core"
  }
}
